# Decompose has NO database — the panel is generated in-process. There is no
# DATABASE_URL and no credentials to set. These two are optional runtime knobs only.

# Flask session secret (a random one is generated if unset — fine for a public demo).
# FLASK_SECRET_KEY=change-me

# Local dev port (defaults to 8050).
# PORT=8050

# Set to "true" to run the Dash dev server with debug on (local only).
# FLASK_DEBUG=false
